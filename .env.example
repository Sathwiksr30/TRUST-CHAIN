# ═══════════════════════════════════════════════════════════════════════════════
# TRUSTCHAIN - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your values before running the project
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (React) Configuration
# ─────────────────────────────────────────────────────────────────────────────
REACT_APP_API_BASE_URL=http://localhost:5000
REACT_APP_PORT=3000

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND (Node.js Express) Configuration
# ─────────────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# API Authentication (change this to a secure value in production)
API_KEY=trustchain_dummy_key

# ML Service (Python Flask - certificate validation)
ML_SERVICE_URL=http://localhost:5002

# ─────────────────────────────────────────────────────────────────────────────
# BLOCKCHAIN (Hardhat Local RPC) Configuration
# ─────────────────────────────────────────────────────────────────────────────
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337

# DigitalWill Smart Contract
DIGITAL_WILL_CONTRACT_ADDRESS=
DIGITAL_WILL_OWNER_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# WILL Execution Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Default time delay before will can be executed after creation (in seconds)
# Default: 86400 = 24 hours
WILL_DEFAULT_RELEASE_DELAY_SECONDS=86400

# Buffer time for death condition processing (in seconds)
WILL_DEATH_RELEASE_BUFFER_SECONDS=30

# Auto-funding amount for new wills (in ETH)
WILL_AUTO_FUND_ETH=1

# Minimum required funds for will execution (in ETH)
WILL_MIN_EXECUTION_FUND_ETH=1

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL / SMTP Configuration (for notifications)
# ─────────────────────────────────────────────────────────────────────────────
# For Gmail: get an App Password from https://myaccount.google.com/apppasswords
# Leave EMAIL_USER and EMAIL_PASS blank for development (console-only mode)
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=TrustChain <noreply@trustchain.io>

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON ML SERVICE Configuration
# ─────────────────────────────────────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
ML_SERVICE_PORT=5002
IPFS_UPLOAD_URL=http://localhost:5000/upload-ipfs

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING & DEBUG Configuration
# ─────────────────────────────────────────────────────────────────────────────
REQUEST_LOG_LEVEL=minimal
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# IPFS Configuration
# ─────────────────────────────────────────────────────────────────────────────
IPFS_ENABLED=true
IPFS_REPO_PATH=./ipfs-repo
