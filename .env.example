# ═══════════════════════════════════════════════════════════════════════════════
# TRUSTCHAIN - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your values before running/deploying the project
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (React) - Deployment: VERCEL
# ─────────────────────────────────────────────────────────────────────────────
# The live URL of your Render backend (e.g., https://trustchain-backend.onrender.com)
REACT_APP_API_BASE_URL=
# Use "sepolia" for production deployment
REACT_APP_NETWORK=sepolia
# Your Sepolia RPC URL (Alchemy/Infura)
REACT_APP_RPC_URL=
# The deployed DigitalWill contract address on Sepolia
REACT_APP_DIGITAL_WILL_CONTRACT_ADDRESS=
# Optional: API Key for backend communication
REACT_APP_API_KEY=trustchain_dummy_key

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND (Node.js Express) - Deployment: RENDER
# ─────────────────────────────────────────────────────────────────────────────
PORT=10000
NODE_ENV=production
# The URL of your live frontend (e.g., https://trust-chain.vercel.app)
FRONTEND_URL=
# The external URL of the backend itself (usually set by Render)
BACKEND_URL=
# API Authentication
API_KEY=trustchain_dummy_key

# ── ML Service ──
# The live URL of your Render ML service (e.g., https://trustchain-ml.onrender.com)
ML_SERVICE_URL=

# ── Blockchain (Sepolia) ──
BLOCKCHAIN_RPC_URL=
BLOCKCHAIN_CHAIN_ID=11155111
DIGITAL_WILL_CONTRACT_ADDRESS=
DIGITAL_WILL_OWNER_PRIVATE_KEY=

# ── IPFS ──
# Set to true for IPFS storage (requires Helia/local IPFS nodes or Pinata integration)
IPFS_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# WILL Execution & Logic
# ─────────────────────────────────────────────────────────────────────────────
# Default delay (in seconds) - 86400 = 24 hours
WILL_DEFAULT_RELEASE_DELAY_SECONDS=86400
# Buffer for processing - 30 seconds
WILL_DEATH_RELEASE_BUFFER_SECONDS=30
# Auto-funding for new wills (in ETH) - 0.01 for testnet
WILL_AUTO_FUND_ETH=0.01
# Minimum funds for execution - 0.01 for testnet
WILL_MIN_EXECUTION_FUND_ETH=0.01

# Allow any death certificate (for testing/demo)
ALLOW_ANY_DEATH_CERTIFICATE=true

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL / SMTP (for notifications)
# ─────────────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=TrustChain <noreply@trustchain.shop>
# OR use Resend
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON ML SERVICE - Deployment: RENDER
# ─────────────────────────────────────────────────────────────────────────────
# The backend URL for IPFS uploads (set to your Render backend URL)
IPFS_UPLOAD_URL=
